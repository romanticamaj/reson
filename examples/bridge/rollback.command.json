{
  "schemaVersion": "siann.command.v0",
  "journalPath": "/tmp/siann-demo/rollback/journal.json",
  "batchRisk": "normal",
  "snapshotRetention": {
    "maxCount": 3
  },
  "commands": [
    {
      "op": "create_session",
      "sessionDir": "/tmp/siann-demo/rollback/Session",
      "sessionName": "RollbackDemo",
      "sampleRate": 48000
    },
    {
      "op": "create_audio_track",
      "name": "Rollback Target",
      "inputChannels": 1,
      "outputChannels": 2,
      "count": 1
    },
    {
      "op": "save_session"
    }
  ]
}
