{
  "schemaVersion": "reson.command.v0",
  "journalPath": "/tmp/reson-bridge-demo/create-session/journal.json",
  "batchRisk": "low",
  "snapshotRetention": {
    "maxCount": 3
  },
  "commands": [
    {
      "op": "create_session",
      "sessionDir": "/tmp/reson-bridge-demo/create-session/Session",
      "sessionName": "BridgeDemo",
      "sampleRate": 48000
    },
    {
      "op": "create_audio_track",
      "name": "Audio A",
      "inputChannels": 1,
      "outputChannels": 2,
      "count": 1
    },
    {
      "op": "save_session"
    },
    {
      "op": "observe_session"
    }
  ]
}
